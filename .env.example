# Media source: cloudinary | local
# - cloudinary: load from Cloudinary CDN (requires cloud name below)
# - local: load from public/assets and public/content on disk
VITE_MEDIA_SOURCE=cloudinary

# Cloudinary — required when VITE_MEDIA_SOURCE=cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_FOLDER=mellowyellow

# Upload script only — never commit real values
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=mellowyellow
